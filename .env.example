# Vercel Dashboard → Project Settings → Environment Variables 에 등록
# (로컬 개발 시 .env.local 에 같은 값 입력)

ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROK_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LAW_GO_KR_OC=your_email_id

# 공공데이터포털(data.go.kr) 인증키 — datagovkr/crime-stats/watch-g2b 공용
DATA_GO_KR_KEY=your_data_go_kr_decoding_key

# --- 나라장터 입찰공고 키워드 알림 (/api/watch-g2b) ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
WATCH_KEYWORDS=인공지능,데이터 구축,LLM
# 선택값 (미설정 시 기본값)
# WATCH_CATEGORIES=thng,servc,cnstwk,frgcpt   # 물품,용역,공사,외자
# WATCH_LOOKBACK_HOURS=24
# G2B_BASE_URL=http://apis.data.go.kr/1230000/ad/BidPublicInfoService
# CRON_SECRET=long_random_string

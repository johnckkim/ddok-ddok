# Vercel Dashboard → Project Settings → Environment Variables 에 등록
# (로컬 개발 시 .env.local 에 같은 값 입력)

ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROK_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LAW_GO_KR_OC=your_email_id

# 공공데이터포털(data.go.kr) 인증키 — datagovkr/crime-stats/watch-g2b 공용
DATA_GO_KR_KEY=your_data_go_kr_decoding_key

# --- 나라장터 입찰공고 키워드 알림 (/api/watch-g2b) ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
WATCH_KEYWORDS=베리어프리,대형폐기물,키오스크,무인배출신소시스템,베리어프리+유지보수,대형폐기물+유지보수,키오스크+유지보수,무인배출신소시스템+유지보수
# 선택값 (미설정 시 기본값)
# WATCH_CATEGORIES=thng,servc,cnstwk,frgcpt   # 물품,용역,공사,외자
# WATCH_LOOKBACK_HOURS=48
# G2B_BASE_URL=https://apis.data.go.kr/1230000/ad/BidPublicInfoService
# CRON_SECRET=long_random_string
# --- Notion 정리 + 중복판별(하루 여러 번 실행 시 권장) ---
# NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTION_TITLE_PROP=공고명
# NOTION_BIDNO_PROP=공고번호
